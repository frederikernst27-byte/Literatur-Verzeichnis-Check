# --- KI-Fallback (empfohlen: Gemini 2.5 Flash mit Search-Grounding) ---
# Wenn USE_AI=false, läuft nur die kostenlose API-Prüfung (CrossRef/OpenAlex/Semantic Scholar).
# Mit USE_AI=true wird für unsichere Fälle (Score < 80%) zusätzlich die KI befragt.
USE_AI=true
# gemini (empfohlen) oder openrouter
AI_PROVIDER=gemini

# Google AI Studio Key (kostenlos): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Alternative: OpenRouter (":online"-Modell für Websuche)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- E-Mail-Bot (nur für email_bot.py nötig) ---
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Wie oft (Sekunden) das Postfach geprüft wird
POLL_INTERVAL_SECONDS=60
