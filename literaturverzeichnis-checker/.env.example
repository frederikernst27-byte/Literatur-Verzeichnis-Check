# --- KI-Fallback (empfohlen: OpenRouter mit Gemini 2.5 Flash) ---
# Wenn USE_AI=false, läuft nur die kostenlose API-Prüfung (CrossRef/OpenAlex/Semantic Scholar).
# Mit USE_AI=true wird für unsichere Fälle (Score < 80%) zusätzlich die KI befragt.
USE_AI=true
# openrouter (empfohlen) oder gemini
AI_PROVIDER=openrouter

# OpenRouter: Account auf https://openrouter.ai anlegen.
# Wird mit Gemini 2.5 Flash + Websuche genutzt (:online wird automatisch angehängt).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Alternative: Google AI Studio Key (kostenlos): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- E-Mail-Bot (nur für email_bot.py nötig) ---
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Wie oft (Sekunden) das Postfach geprüft wird
POLL_INTERVAL_SECONDS=60
